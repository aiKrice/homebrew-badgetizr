# Brewfile - Dependencies for Badgetizr development on macOS
# Run: brew bundle

# Core dependencies
brew "gh"              # GitHub CLI
brew "glab"            # GitLab CLI
brew "yq"              # YAML processor

# Development tools
brew "shellcheck"      # Shell script linter
brew "bats-core"       # Bash Automated Testing System
brew "kcov"            # Code coverage tool
